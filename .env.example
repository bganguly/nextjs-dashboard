# Copy to .env and fill in real values (the .env file is gitignored).
# tests/notify.ts sends blocked-test alerts to every channel configured below.

# --- Email (Gmail) ---
# NOTIFY_PASS must be a Gmail App Password (requires 2FA):
# https://myaccount.google.com/apppasswords
NOTIFY_EMAIL=you@gmail.com
NOTIFY_PASS=your-app-password

# --- Telegram ---
# Create a bot with @BotFather to get the token, then message the bot once and
# read your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
