generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  slug      String     @unique @db.VarChar(100)
  parentId  Int?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("categories")
}

model Region {
  id        Int        @id @default(autoincrement())
  code      String     @unique @db.VarChar(10)
  name      String     @db.VarChar(100)
  country   String     @db.VarChar(100)
  timezone  String     @db.VarChar(50)
  customers Customer[]
  orders    Order[]

  @@map("regions")
}

model Customer {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  phone     String?  @db.VarChar(30)
  regionId  Int
  region    Region   @relation(fields: [regionId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([email])
  @@index([lastName]) // sort orders by customer (customer.lastName)
  @@map("customers")
}

model Product {
  id          Int         @id @default(autoincrement())
  sku         String      @unique @db.VarChar(100)
  name        String      @db.VarChar(255)
  description String?
  price       Decimal     @db.Decimal(10, 2)
  cost        Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([sku])
  @@map("products")
}

model Order {
  id         Int         @id @default(autoincrement())
  customerId Int
  customer   Customer    @relation(fields: [customerId], references: [id])
  regionId   Int
  region     Region      @relation(fields: [regionId], references: [id])
  status     OrderStatus @default(PENDING)
  total      Decimal     @db.Decimal(12, 2)
  currency   String      @default("USD") @db.VarChar(3)
  notes      String?
  placedAt   DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]
  auditLogs  AuditLog[]

  @@index([customerId])
  @@index([customerId, placedAt])
  @@index([regionId])
  @@index([regionId, placedAt])
  @@index([status])
  @@index([status, placedAt])
  @@index([status, regionId, placedAt])
  @@index([placedAt])
  @@index([total]) // sort-by-total at 4M rows
  @@index([total, placedAt])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderCategoryFact {
  orderId      Int
  placedAt     DateTime
  date         DateTime @db.Date
  regionId     Int?
  regionCode   String?  @db.VarChar(10)
  status       OrderStatus?
  orderTotal   Decimal? @db.Decimal(12, 2)
  categoryId   Int
  categoryName String   @db.VarChar(100)
  totalItems   Int      @default(0)
  totalRevenue Decimal  @default(0) @db.Decimal(14, 2)

  @@id([orderId, categoryId])
  @@index([orderId])
  @@index([date])
  @@index([date, orderTotal])
  @@index([date, orderTotal, categoryName])
  @@index([status, date, orderTotal])
  @@index([status, date, orderTotal, categoryName])
  @@index([regionCode, date, status, orderTotal])
  @@index([regionCode, status, date, orderTotal, categoryName])
  @@map("order_category_facts")
}

model DailySummary {
  id            Int      @id @default(autoincrement())
  date          DateTime @db.Date
  categoryId    Int
  categoryName  String   @db.VarChar(100)
  regionId      Int
  regionCode    String   @db.VarChar(10)
  totalOrders   Int      @default(0)
  totalRevenue  Decimal  @default(0) @db.Decimal(14, 2)
  totalItems    Int      @default(0)
  avgOrderValue Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, categoryId, regionId])
  @@index([date])
  @@index([categoryId])
  @@index([regionId])
  @@index([regionCode, date])
  @@map("daily_summary")
}

model DailyFilterCategorySummary {
  id            Int         @id @default(autoincrement())
  date          DateTime    @db.Date
  regionId      Int
  regionCode    String      @db.VarChar(10)
  status        OrderStatus
  categoryId    Int
  categoryName  String      @db.VarChar(100)
  totalOrders   Int         @default(0)
  totalRevenue  Decimal     @default(0) @db.Decimal(14, 2)
  totalItems    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([date, regionId, status, categoryId])
  @@index([date, status])
  @@index([status, date, categoryName])
  @@index([date, status, regionId])
  @@index([regionCode, status, date, categoryName])
  @@index([regionCode, date, status])
  @@map("daily_filter_category_summary")
}

model DailyStatusCategorySummary {
  id           Int         @id @default(autoincrement())
  date         DateTime    @db.Date
  status       OrderStatus
  categoryId   Int
  categoryName String      @db.VarChar(100)
  totalOrders  Int         @default(0)
  totalRevenue Decimal     @default(0) @db.Decimal(14, 2)
  totalItems   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([date, status, categoryId])
  @@index([status, date, categoryName])
  @@map("daily_status_category_summary")
}

model DailyCustomerCategorySummary {
  id            Int         @id @default(autoincrement())
  date          DateTime    @db.Date
  customerId    Int
  regionId      Int
  regionCode    String      @db.VarChar(10)
  status        OrderStatus
  categoryId    Int
  categoryName  String      @db.VarChar(100)
  totalOrders   Int         @default(0)
  totalRevenue  Decimal     @default(0) @db.Decimal(14, 2)
  totalItems    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([date, customerId, regionId, status, categoryId])
  @@index([customerId, date])
  @@index([date, status])
  @@index([status, date, customerId, categoryName])
  @@index([date, regionId])
  @@index([date, status, regionId])
  @@index([regionCode, date])
  @@index([regionCode, date, customerId, categoryName])
  @@index([regionCode, status, date, customerId, categoryName])
  @@map("daily_customer_category_summary")
}

model DailyCustomerTokenCategorySummary {
  id            Int         @id @default(autoincrement())
  date          DateTime    @db.Date
  token         String      @db.VarChar(255)
  regionId      Int
  regionCode    String      @db.VarChar(10)
  status        OrderStatus
  categoryId    Int
  categoryName  String      @db.VarChar(100)
  totalOrders   Int         @default(0)
  totalRevenue  Decimal     @default(0) @db.Decimal(14, 2)
  totalItems    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([date, token, regionId, status, categoryId])
  @@index([token, date])
  @@index([token, date, status])
  @@index([token, date, regionId])
  @@index([token, date, status, regionId])
  @@index([token, regionCode, date])
  @@map("daily_customer_token_category_summary")
}

model DailyCustomerTokenCategoryRollup {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  token        String   @db.VarChar(255)
  categoryId   Int
  categoryName String   @db.VarChar(100)
  totalOrders  Int      @default(0)
  totalRevenue Decimal  @default(0) @db.Decimal(14, 2)
  totalItems   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, token, categoryId])
  @@index([token, date])
  @@map("daily_customer_token_category_rollup")
}

model DailyCustomerTokenOrderSummary {
  id           Int         @id @default(autoincrement())
  date         DateTime    @db.Date
  token        String      @db.VarChar(255)
  regionId     Int
  regionCode   String      @db.VarChar(10)
  status       OrderStatus
  totalOrders  Int         @default(0)
  totalRevenue Decimal     @default(0) @db.Decimal(14, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([date, token, regionId, status])
  @@index([token, date])
  @@index([token, date, status])
  @@index([token, date, regionId])
  @@index([token, date, status, regionId])
  @@index([token, regionCode, date])
  @@map("daily_customer_token_order_summary")
}

model SearchIndex {
  id         Int      @id @default(autoincrement())
  entityType String   @db.VarChar(50)
  entityId   Int
  content    String
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@map("search_index")
}

model Session {
  id        String   @id @db.VarChar(128)
  userId    Int
  data      Json?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  entityType String   @db.VarChar(50)
  entityId   Int
  action     String   @db.VarChar(50)
  actorId    Int?
  before     Json?
  after      Json?
  orderId    Int?
  order      Order?   @relation(fields: [orderId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_log")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
